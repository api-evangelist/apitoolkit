      "id": "0acaf162-099e-405c-aa6e-dd885e090338",
      "name": "Metrics",
      "description": {
        "content": "Query timeseries and aggregate metric data.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "5fb6e4b8-21e4-4224-bda6-7a21d061165e",
          "name": "Query Metrics",
          "request": {
            "name": "Query Metrics",
            "description": {
              "content": "Query metrics for a project using either a predefined metric query\nexpression or raw SQL. Supports relative (`since`) or absolute\n(`from`/`to`) time ranges, and a `source` filter for `http`, `logs`,\nor `traces` data.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "metrics"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "pid",
                  "value": "<uuid>",
                  "description": "(Required) Project ID (UUID) to scope the request."
                },
                {
                  "disabled": false,
                  "key": "data_type",
                  "value": "<string>",
                  "description": "Category of metric information to return."
                },
                {
                  "disabled": false,
                  "key": "query",
                  "value": "<string>",
                  "description": "Predefined metric query expression."
                },
                {
                  "disabled": false,
                  "key": "query_sql",
                  "value": "<string>",
                  "description": "Advanced querying using raw SQL syntax."
                },
                {
                  "disabled": false,
                  "key": "since",
                  "value": "<string>",
                  "description": "Relative time specification (e.g. `1h`, `24h`, `7d`)."
                },
                {
                  "disabled": false,
                  "key": "from",
                  "value": "<dateTime>",
                  "description": "Beginning point for absolute time range (ISO 8601)."
                },
                {
                  "disabled": false,
                  "key": "to",
                  "value": "<dateTime>",
                  "description": "Ending point for absolute time range (ISO 8601)."
                },
                {
                  "disabled": false,
                  "key": "source",
                  "value": "<string>",
                  "description": "Metric origin filter."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
